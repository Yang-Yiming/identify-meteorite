{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "allow",
      "rm": "ask",
      "mv": "ask"
    },
    "edit": {
      "*": "allow",
      "my-autoresearch/config/program.md": "deny",
      "my-autoresearch/config/project.md": "deny",
      "my-autoresearch/scripts/**": "deny",
      "my-autoresearch/opencode.json": "ask",
      "my-autoresearch/config/autoresearch.config.json": "ask"
    }
  }
}
